# Backend can be:
# - openai_http: forward to an OpenAI-compatible HTTP endpoint
# - codex_cli: call local `codex exec` using your official Codex CLI login state
# - codex_app_server: call local `codex app-server --stdio` using your official Codex CLI login state
GATEWAY_BACKEND=openai_http

# Upstream OpenAI-compatible endpoint.
# For OpenAI API, keep the default base URL and set UPSTREAM_API_KEY.
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=

# Optional: force all child agents onto one central model.
# If empty, the gateway uses agent model config, then the request's model.
CENTER_MODEL=
PUBLIC_MODEL_ID=
CODEX_INTERNAL_MODEL=

# Codex backend settings. Do not put your OpenAI/Codex account password here.
# Run `codex login` yourself in a terminal before using a Codex backend.
CODEX_COMMAND=codex
CODEX_HOME=/Users/lzp/mutilpleagent/.codex-gateway-home
CODEX_WORKDIR=/Users/lzp/mutilpleagent
CODEX_SANDBOX=workspace-write
CODEX_TIMEOUT_SECONDS=600
GATEWAY_ORCHESTRATION_MAX_STEPS=4

# Optional proxy for Codex CLI/OpenAI network calls.
HTTP_PROXY=http://127.0.0.1:10792
HTTPS_PROXY=http://127.0.0.1:10792
ALL_PROXY=http://127.0.0.1:10792
NO_PROXY=localhost,127.0.0.1

# Agent config and session database.
AGENTS_FILE=agents.json
SESSION_DB=sessions.sqlite3
DEFAULT_USER_ID=local-user
DEFAULT_WORKSPACE_ID=default-workspace
REQUIRE_USER_AUTH=false
AUTH_TOKEN_TTL_SECONDS=2592000

# Optional env-only agent key mapping. Format:
# AGENT_KEYS=planner=planner-local-key,coder=coder-local-key
AGENT_KEYS=

# Default maximum stored history messages injected per stateful request.
SESSION_HISTORY_LIMIT=40
