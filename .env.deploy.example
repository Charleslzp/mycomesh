# Copy this file to .env.deploy before using docker compose.

# Gateway backend:
# - openai_http is for local/non-settlement use with an OpenAI-compatible API.
# - codex_app_server requires a Codex CLI login state mounted at CODEX_HOME.
# - testnet Codex Providers use codex_app_server and an isolated ChatGPT login.
GATEWAY_BACKEND=openai_http
# These upstream values are ignored by codex_app_server. Its testnet preflight
# requires UPSTREAM_API_KEY to stay empty so API-key auth cannot replace login.
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=
UPSTREAM_TIMEOUT_SECONDS=180
# Limits apply to decoded upstream bodies; values above 268435456 are rejected.
UPSTREAM_MAX_RESPONSE_BYTES=33554432
UPSTREAM_MAX_STREAM_BYTES=33554432
# Signed native-metering values belong only to the alternate native-metered
# backend. They remain empty for the ChatGPT-backed Codex Provider path.
UPSTREAM_EXPECTED_MODEL_REVISION=
UPSTREAM_METERING_PUBLIC_KEY=
UPSTREAM_CAPABILITIES_SHA256=
UPSTREAM_METERING_AUDIENCE=
UPSTREAM_DEFAULT_MAX_OUTPUT_TOKENS=2000
CENTER_MODEL=
PUBLIC_MODEL_ID=mycomesh-codex-standard-v1
CODEX_INTERNAL_MODEL=gpt-5.5
MYCOMESH_RESERVE_INPUT_TOKENS=8000
MYCOMESH_RESERVE_OUTPUT_TOKENS=2000
# Provider Compose pins the sandbox to read-only and concurrency to one. Leave
# CODEX_PROVIDER_BASE_URL empty for the official Codex service. Public testnet
# Provider startup rejects any custom value so ChatGPT credentials cannot be
# redirected. The explicit override exists only for isolated local development.
CODEX_PROVIDER_BASE_URL=
CODEX_MODEL_PROVIDER=mycomesh
CODEX_PROVIDER_NAME=MycoMesh Codex Provider
CODEX_PROVIDER_WIRE_API=responses
MYCOMESH_CODEX_TESTNET_METERING=false
CODEX_TESTNET_MAX_OUTPUT_TOKENS=2000
# Applied by ASGI middleware before any route or JSON parser reads the body.
GATEWAY_MAX_REQUEST_BYTES=16777216
# ASGI admission and request-body deadlines. Uvicorn flags add a first server-side
# cap; a public deployment still needs a reverse proxy with a header-read deadline.
GATEWAY_MAX_CONCURRENT_REQUESTS=128
GATEWAY_REQUEST_BODY_TIMEOUT_SECONDS=30
GATEWAY_UVICORN_LIMIT_CONCURRENCY=128
GATEWAY_UVICORN_KEEP_ALIVE_SECONDS=5
GATEWAY_UVICORN_H11_MAX_INCOMPLETE_EVENT_BYTES=65536
# Local Codex process output/event retention limits. Provider Compose overrides
# concurrency to one even if the shared standalone Gateway value below is higher.
CODEX_MAX_CONCURRENT_PROCESSES=4
CODEX_STDOUT_MAX_BYTES=8388608
CODEX_STDERR_MAX_BYTES=1048576
CODEX_APP_SERVER_STDOUT_MAX_BYTES=33554432
CODEX_APP_SERVER_STDERR_RETAIN_BYTES=1048576
CODEX_APP_SERVER_MAX_MESSAGES=100000
# Live app-server processes waiting for function_call_output are bounded and expire.
CODEX_APP_SERVER_MAX_PENDING_TURNS=8
CODEX_APP_SERVER_PENDING_TTL_SECONDS=300

# Default agent key mapping used by the gateway container.
# Replace these before exposing a public service.
AGENT_KEYS=coder=change-me-coder-key

# Host workspace for the standalone development Gateway. The Provider service
# uses an isolated named volume so inference cannot read this repository's env.
MYCOMESH_WORKSPACE=.

# Shared mutable state belongs only to the Consumer Proxy and Indexer. Compose
# does not expose this PostgreSQL credential to Bridge, Relay, or Provider.
# Replace every change-me value together and URL-encode DSN reserved characters.
MYCOMESH_POSTGRES_DB=mycomesh
MYCOMESH_POSTGRES_USER=mycomesh
MYCOMESH_POSTGRES_PASSWORD=change-me-database-password
MYCOMESH_BILLING_DB=postgresql://mycomesh:change-me-database-password@postgres:5432/mycomesh
# Single-process Relay and Provider replay stores are fixed to separate SQLite
# files in their own /data volumes. Custom multi-replica deployments must supply
# a separately permissioned transactional replay database outside this Compose.
# Existing single-process proxy billing deployments may override:
# MYCOMESH_BILLING_DB=/data/mycomesh-billing.sqlite3

# MycoMesh network settings.
MYCOMESH_CHANNEL=codex-standard-v1
MYCOMESH_NETWORK_ID=mycomesh-local

# Browser CORS is disabled when these exact-origin allowlists are empty. Values
# are comma-separated origins only: no paths, wildcards, `null`, or credentials.
# HTTPS is required except for explicit localhost/loopback development origins.
MYCOMESH_CORS_ALLOWED_ORIGINS=
MYCOMESH_POOL_CORS_ALLOWED_ORIGINS=
# mycomesh.xyz production web origins (both the homepage and dApp may read live
# status; only the Consumer Proxy accepts authenticated browser API requests):
# MYCOMESH_CORS_ALLOWED_ORIGINS=https://mycomesh.xyz,https://app.mycomesh.xyz
# MYCOMESH_POOL_CORS_ALLOWED_ORIGINS=https://mycomesh.xyz,https://app.mycomesh.xyz

# local is for private smoke tests and uses plaintext tcp:// or relay://.
# Non-local providers advertise signed myco+tcp:// or myco+relays:// endpoints
# with sealed request/response frames. A non-local Gateway also refuses startup
# unless its inference backend reports production-safe cap and usage support.
MYCOMESH_NETWORK_PROFILE=local
MYCOMESH_POOL_PUBLIC_URL=http://127.0.0.1:9800

# Bridge operator. Testnet uses structured values so arbitrary CLI flags cannot
# weaken admission, address verification or reputation authentication.
MYCOMESH_BRIDGE_ADMISSION_MODE=allowlist
MYCOMESH_BRIDGE_PROVIDER_PUBLIC_KEYS=
MYCOMESH_BRIDGE_REPUTATION_SIGNER_PUBLIC_KEYS=
MYCOMESH_BRIDGE_TRUST_PROXY_HEADERS=false
MYCOMESH_BRIDGE_TRUSTED_RELAY_ORIGINS=
# Local/demo only. This must be exactly empty in testnet.
MYCOMESH_BRIDGE_EXTRA_ARGS=--skip-direct-address-verification --allow-any-reputation-signer
# Public-node testnet values for the canonical mycomesh.xyz deployment:
# MYCOMESH_NETWORK_PROFILE=testnet
# MYCOMESH_NETWORK_ID=mycomesh-testnet
# MYCOMESH_POOL_PUBLIC_URL=https://bridge.mycomesh.xyz
# MYCOMESH_BRIDGE_ADMISSION_MODE=any-signed
# MYCOMESH_BRIDGE_PROVIDER_PUBLIC_KEYS=
# MYCOMESH_BRIDGE_REPUTATION_SIGNER_PUBLIC_KEYS=<proxy-ed25519-public-key>
# MYCOMESH_BRIDGE_TRUST_PROXY_HEADERS=true
# MYCOMESH_BRIDGE_TRUSTED_RELAY_ORIGINS=https://bridge.mycomesh.xyz
# MYCOMESH_BRIDGE_EXTRA_ARGS=
# Use admission mode allowlist instead of any-signed and provide comma-separated
# Provider public keys when onboarding is manual. Permissionless admission still
# requires signed descriptors and either a callback-verified public direct endpoint
# or a trusted myco+relays:// endpoint with end-to-end Provider address proof,
# plus a payment address and the pinned V3 settlement fields.
# Trusted proxy headers are safe here only because Compose binds Bridge HTTP to
# 127.0.0.1 and the same-host Nginx proxy overwrites X-Real-IP. The `open`
# network profile remains disabled until staking, slashing and disputes exist.

# Provider operator. The identity and runtime state live on the provider-only
# Docker volume; generate its signed node identity with make provider-identity.
# A permissionless signed-Provider Bridge does not require pre-registering this
# Production provider-* targets load all public discovery values from the
# versioned network config. These local/demo defaults are not duplicated into
# the production process. The EVM private key is generated only in /data.
MYCOMESH_PROVIDER_NETWORK_CONFIG=
MYCOMESH_PROVIDER_EVM_IDENTITY=/data/provider-evm-identity.json
# Local/demo transport values:
# public key. With all testnet values below complete, make provider-up performs
# the signed join automatically and maintains the Bridge lease by heartbeat.
MYCOMESH_PROVIDER_TRANSPORT=direct
MYCOMESH_PROVIDER_IDENTITY=/data/node-identity.json
MYCOMESH_PROVIDER_RUN_DIR=/data/run
MYCOMESH_PROVIDER_POOL_URL=http://bridge:9800
# Testnet defaults to Bridge-observed public IPv4 discovery. The Bridge still
# verifies the advertised address by connecting back to this Provider.
MYCOMESH_PROVIDER_ADVERTISE_HOST=auto
MYCOMESH_PROVIDER_ADVERTISE_PORT=9700
MYCOMESH_PROVIDER_CAPACITY=1
MYCOMESH_PROVIDER_TTL_SECONDS=30
MYCOMESH_PROVIDER_HEARTBEAT_INTERVAL_SECONDS=10
MYCOMESH_PROVIDER_CONSUMER_PUBLIC_KEY=
MYCOMESH_PROVIDER_PAYMENT_ADDRESS=
MYCOMESH_PROVIDER_PRICING_HASH=
# Local/demo default only. Testnet preflight rejects every development allow flag.
MYCOMESH_PROVIDER_EXTRA_ARGS=--allow-any-signed-consumer --allow-unreserved-requests
# A direct testnet Provider requires all of the following. Its Bridge URL must be
# the exact canonical HTTPS audience configured by that Bridge.
# GATEWAY_BACKEND=codex_app_server
# UPSTREAM_API_KEY=
# PUBLIC_MODEL_ID=<network-facing-model-id>
# CODEX_INTERNAL_MODEL=<Codex-model-id>
# CODEX_PROVIDER_BASE_URL=
# MYCOMESH_CODEX_TESTNET_METERING=true
# CODEX_TESTNET_MAX_OUTPUT_TOKENS=2000
# Testnet requires CODEX_PROVIDER_BASE_URL to remain empty. Run
# 'make provider-login' once, then 'make provider-up'; both use the persistent
# provider-only Docker volume and never mount the host's ~/.codex directory.
# MYCOMESH_NETWORK_PROFILE=testnet
# MYCOMESH_PROVIDER_POOL_URL=https://bridge.mycomesh.xyz
# MYCOMESH_PROVIDER_ADVERTISE_HOST=auto
# MYCOMESH_PROVIDER_ADVERTISE_PORT=9700
# MYCOMESH_PROVIDER_BIND_ADDRESS=0.0.0.0
# MYCOMESH_PROVIDER_CONSUMER_PUBLIC_KEY=<proxy-request-ed25519-public-key>
# MYCOMESH_PROVIDER_PAYMENT_ADDRESS=<provider-evm-payment-address>
# MYCOMESH_PROVIDER_EXTRA_ARGS=
# The testnet Compose preflight requires this value to be exactly empty. Do not
# put local allow/bypass flags or other argparse overrides here.
# Testnet startup requires the isolated login to report ChatGPT auth, the local
# Gateway /ready endpoint to report settlement_ready=true, and a live signed
# Bridge join/heartbeat. /health alone is only process liveness.

# Relay operator:
MYCOMESH_RELAY_ADVERTISE_HOST=127.0.0.1
MYCOMESH_RELAY_PUBLIC_URL=http://127.0.0.1:9900
MYCOMESH_RELAY_CONSUMER_PUBLIC_KEYS=
MYCOMESH_RELAY_ALLOW_ANY_SIGNED_CONSUMER=false
MYCOMESH_RELAY_TRUST_PROXY_HEADERS=false
# Local/demo only. This must be exactly empty in testnet.
MYCOMESH_RELAY_EXTRA_ARGS=--allow-any-signed-consumer
# Public-node testnet values. Relay control stays on host loopback behind Nginx;
# Provider ingress is TLS-terminated by host Nginx on bridge.mycomesh.xyz:9901;
# the Docker Relay backend remains bound to host loopback. Values are public identities, not
# private keys, and multiple Consumer keys are comma-separated.
# MYCOMESH_RELAY_ADVERTISE_HOST=bridge.mycomesh.xyz
# MYCOMESH_RELAY_PUBLIC_URL=https://bridge.mycomesh.xyz
# MYCOMESH_RELAY_ALLOW_ANY_SIGNED_CONSUMER=true
# MYCOMESH_RELAY_TRUST_PROXY_HEADERS=true
# MYCOMESH_RELAY_CONSUMER_PUBLIC_KEYS=<proxy-ed25519-public-key>
# MYCOMESH_RELAY_EXTRA_ARGS=
# Payloads remain end-to-end sealed between Consumer and Provider; the Relay can
# still observe routing metadata. Replay state is persisted only in the
# Relay-owned /data/relay-replay.sqlite3 volume.

# Consumer proxy settings.
# Local placeholder only. Non-local profiles reject placeholders and secrets
# shorter than 32 characters.
MYCOMESH_ADMIN_TOKEN=change-me-admin-token
MYCOMESH_BILLING_MODE=local
# The production Compose proxy overrides billing to onchain-prepaid and V3;
# these bounds control its persistent confirmed-event cache.
MYCOMESH_ALLOW_LOCAL_BALANCE_CACHE=true
MYCOMESH_CHAIN_SYNC_MAX_AGE_SECONDS=120
MYCOMESH_CHAIN_SYNC_MAX_BLOCK_LAG=12
MYCOMESH_INDEXER_STATE=/data/mycomesh-indexer.json
MYCOMESH_INDEXER_SYNC_INTERVAL_SECONDS=30
MYCOMESH_INDEXER_RETRY_SECONDS=10
MYCOMESH_INDEXER_LOOKBACK_BLOCKS=100
MYCOMESH_INDEXER_CHUNK_BLOCKS=100
MYCOMESH_INDEXER_RPC_TIMEOUT_SECONDS=20
# Wallet key registration is disabled by default, including in this local
# template. Set true only when deliberately testing/operating that endpoint.
MYCOMESH_PUBLIC_KEY_REGISTRATION=false
# Shared billing database issuance bounds. Public deployments still need a
# reverse-proxy per-source rate limit before enabling registration.
MYCOMESH_KEY_CHALLENGE_CAPACITY=1024
MYCOMESH_KEY_CHALLENGE_RATE_PER_MINUTE=120
# Contract-wallet registration RPC work is isolated from the ASGI event loop;
# this concurrency bound applies per process.
MYCOMESH_KEY_REGISTRATION_RPC_CONCURRENCY=4
MYCOMESH_KEY_REGISTRATION_RPC_TIMEOUT=20
# Per-challenge verification attempts before the shared claim fails closed.
MYCOMESH_KEY_REGISTRATION_MAX_ATTEMPTS=5
MYCOMESH_ALLOW_PUBLIC_GATEWAY_REGISTRATION=false
MYCOMESH_DISCOVERY_LIMIT=5
MYCOMESH_POOL_URL=http://bridge:9800
# Consumer Proxy request body limit, also enforced for chunked requests.
MYCOMESH_MAX_REQUEST_BYTES=1048576
MYCOMESH_MAX_CONCURRENT_REQUESTS=128
MYCOMESH_REQUEST_BODY_TIMEOUT_SECONDS=30
MYCOMESH_INFERENCE_CONCURRENCY=8
MYCOMESH_TIMEOUT_SECONDS=120
MYCOMESH_UVICORN_LIMIT_CONCURRENCY=128
MYCOMESH_UVICORN_KEEP_ALIVE_SECONDS=5
MYCOMESH_UVICORN_H11_MAX_INCOMPLETE_EVENT_BYTES=65536
# Canonical URL is always required. This value matches the local Docker proxy.
# Public profiles must replace it with an HTTPS URL using public DNS.
# API keys are bound to this URL's origin and are not portable across Gateways.
MYCOMESH_PUBLIC_GATEWAY_URL=http://127.0.0.1:8100/v1
# Public consumer proxy example (requires settlement_ready=true providers):
# MYCOMESH_NETWORK_PROFILE=testnet
# MYCOMESH_NETWORK_ID=mycomesh-testnet
# MYCOMESH_PUBLIC_GATEWAY_URL=https://gateway.example.com/v1
# MYCOMESH_PUBLIC_KEY_REGISTRATION=false
# MYCOMESH_POOL_URL=https://bridge-a.example.com,https://bridge-b.example.com

# Legacy Sepolia MycoMesh V2 deployment. Retained for compatibility/migration.
MYCOMESH_SETTLEMENT_VERSION=2
# Leave blank: V2 falls back to version 1 and V3 reads the immutable version
# from the deployment manifest. A nonblank value is only a consistency pin.
MYCOMESH_PRICING_VERSION=
ETH_CHAIN_ID=11155111
ETH_RPC_URL=https://sepolia.drpc.org,https://rpc.sepolia.ethpandaops.io,https://sepolia.gateway.tenderly.co
MYCO_DEPLOYMENT=/app/deployments/sepolia-myco-v2.json
MYCO_SETTLEMENT=0x780e8daa596981c055148633849a6dd90a0f8d15
MYCO_TOKEN=0x27ce5e8e3811a2664cb66cd1d7aea93f79dff1df
MYCO_TEST_USDC=0x860ccadc1e1926b718cfe4ec24fefa42095c6f68
MYCO_TREASURY=0x8d13f6c18ae30f223d985f39050cc8d9b00f90e1
MYCO_CHANNEL_HASH=0xdedf8b58276b80863f354409c963cbaddf4ca7d5b866d528ff1386d74b339104
MYCOMESH_CHAIN_SYNC_MIN_CONFIRMATIONS=6
MYCOMESH_SETTLEMENT_RPC_URL=https://sepolia.drpc.org,https://rpc.sepolia.ethpandaops.io,https://sepolia.gateway.tenderly.co
MYCOMESH_SETTLEMENT_CONTRACT=
MYCOMESH_SETTLEMENT_CHAIN_ID=
MYCOMESH_SETTLEMENT_CONFIRMATIONS=6
MYCOMESH_SETTLEMENT_RPC_TIMEOUT=20

# V3 example: commit the real public network record at the path below. Docker
# bundles it and fills chain id, settlement address, channel, pricing version,
# and pricing hash automatically. Startup then verifies it at the finalized
# block. Nonblank duplicate env values are accepted only when they match.
# Do not mix these with the V2 addresses above. The deployer's TestUSDC has an
# unrestricted mint and must never be used as a production stablecoin.
# MYCOMESH_SETTLEMENT_VERSION=3
# MYCO_DEPLOYMENT=/app/deployments/sepolia-myco-v3.json
# MYCOMESH_SETTLEMENT_RPC_URL=<v3-rpc-url>
# MYCOMESH_SETTLEMENT_CONFIRMATIONS=6
# MYCOMESH_PROVIDER_CONSUMER_PUBLIC_KEY=<proxy-public-key>
# MYCOMESH_PROVIDER_PAYMENT_ADDRESS=<provider-address>
# MYCOMESH_PROVIDER_EXTRA_ARGS=

# HTTP control planes stay on loopback behind the same-host reverse proxy.
# Direct Provider P2P may be public when selected. Relay Provider ingress is TLS-terminated by host Nginx; its raw Docker backend stays on loopback.
MYCOMESH_PROXY_BIND_ADDRESS=127.0.0.1
MYCOMESH_BRIDGE_BIND_ADDRESS=127.0.0.1
MYCOMESH_PROVIDER_BIND_ADDRESS=127.0.0.1
MYCOMESH_RELAY_CONTROL_BIND_ADDRESS=127.0.0.1
MYCOMESH_RELAY_PROVIDER_BIND_ADDRESS=127.0.0.1
# The public-node profile requires the raw Relay Provider backend on loopback:
# MYCOMESH_RELAY_PROVIDER_BIND_ADDRESS=127.0.0.1
# Published ports on the host.
# Production HTTP upstreams are fixed at 8100, 9800 and 9900 on loopback.
# Relay TLS ingress is fixed at 9901 with its raw backend on 19901. Only the
# standalone development Gateway and direct Provider host ports are configurable.
GATEWAY_PORT=8000
# When this differs from 9700, set MYCOMESH_PROVIDER_ADVERTISE_PORT to the same
# externally reachable host port so the Bridge probes the correct endpoint.
MYCOMESH_PROVIDER_PORT=9700
