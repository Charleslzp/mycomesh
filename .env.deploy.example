# Copy this file to .env.deploy before using docker compose.

# Gateway backend:
# - openai_http is the fastest deployment path and works with any OpenAI-compatible API.
# - codex_app_server requires a Codex CLI login state mounted at CODEX_HOME.
GATEWAY_BACKEND=openai_http
# The provider image includes Codex CLI and uses its isolated login state.
PROVIDER_GATEWAY_BACKEND=codex_app_server
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=
UPSTREAM_TIMEOUT_SECONDS=180
# Limits apply to decoded upstream bodies; values above 268435456 are rejected.
UPSTREAM_MAX_RESPONSE_BYTES=33554432
UPSTREAM_MAX_STREAM_BYTES=33554432
CENTER_MODEL=
PUBLIC_MODEL_ID=gpt-5.5
CODEX_INTERNAL_MODEL=gpt-5.5
# Applied by ASGI middleware before any route or JSON parser reads the body.
GATEWAY_MAX_REQUEST_BYTES=16777216
# ASGI admission and request-body deadlines. Uvicorn flags add a first server-side
# cap; a public deployment still needs a reverse proxy with a header-read deadline.
GATEWAY_MAX_CONCURRENT_REQUESTS=128
GATEWAY_REQUEST_BODY_TIMEOUT_SECONDS=30
GATEWAY_UVICORN_LIMIT_CONCURRENCY=128
GATEWAY_UVICORN_KEEP_ALIVE_SECONDS=5
GATEWAY_UVICORN_H11_MAX_INCOMPLETE_EVENT_BYTES=65536
# Local Codex process output/event retention limits.
CODEX_MAX_CONCURRENT_PROCESSES=4
CODEX_STDOUT_MAX_BYTES=8388608
CODEX_STDERR_MAX_BYTES=1048576
CODEX_APP_SERVER_STDOUT_MAX_BYTES=33554432
CODEX_APP_SERVER_STDERR_RETAIN_BYTES=1048576
CODEX_APP_SERVER_MAX_MESSAGES=100000
# Live app-server processes waiting for function_call_output are bounded and expire.
CODEX_APP_SERVER_MAX_PENDING_TURNS=8
CODEX_APP_SERVER_PENDING_TTL_SECONDS=300

# Default agent key mapping used by the gateway container.
# Replace these before exposing a public service.
AGENT_KEYS=coder=change-me-coder-key

# Host workspace mounted into standalone gateway containers.
MYCOMESH_WORKSPACE=.

# Provider Codex login and workspace storage use dedicated named volumes by
# default. To reuse a host login or workspace, replace the source with an
# absolute path such as /home/myco/.codex or /home/myco/myco-workspace.
MYCOMESH_CODEX_HOME_SOURCE=mycomesh-provider-codex-home
MYCOMESH_PROVIDER_WORKSPACE_SOURCE=mycomesh-provider-workspace

# Shared mutable state for horizontally scaled proxy/provider/relay processes.
# The compose defaults below use its internal PostgreSQL service. Replace every
# change-me value together; URL-encode reserved characters in the two DSNs.
MYCOMESH_POSTGRES_DB=mycomesh
MYCOMESH_POSTGRES_USER=mycomesh
MYCOMESH_POSTGRES_PASSWORD=change-me-database-password
MYCOMESH_BILLING_DB=postgresql://mycomesh:change-me-database-password@postgres:5432/mycomesh
MYCOMESH_REPLAY_DB=postgresql://mycomesh:change-me-database-password@postgres:5432/mycomesh
# Existing single-process SQLite deployments remain supported by overriding:
# MYCOMESH_BILLING_DB=/data/mycomesh-billing.sqlite3
# MYCOMESH_REPLAY_DB=/data/mycomesh-replay.sqlite3

# MycoMesh network settings.
MYCOMESH_CHANNEL=codex-standard-v1
MYCOMESH_NETWORK_ID=mycomesh-local

# Browser CORS is disabled when these exact-origin allowlists are empty. Values
# are comma-separated origins only: no paths, wildcards, `null`, or credentials.
# HTTPS is required except for explicit localhost/loopback development origins.
MYCOMESH_CORS_ALLOWED_ORIGINS=
MYCOMESH_POOL_CORS_ALLOWED_ORIGINS=
# mycomesh.xyz production web origins (both the homepage and dApp may read live
# status; only the Consumer Proxy accepts authenticated browser API requests):
# MYCOMESH_CORS_ALLOWED_ORIGINS=https://mycomesh.xyz,https://app.mycomesh.xyz
# MYCOMESH_POOL_CORS_ALLOWED_ORIGINS=https://mycomesh.xyz,https://app.mycomesh.xyz

# local is for private smoke tests and uses plaintext tcp:// or relay://.
# Non-local providers advertise signed myco+tcp:// or myco+relays:// endpoints
# with sealed request/response frames. A non-local Gateway also refuses startup
# unless its inference backend reports production-safe cap and usage support.
MYCOMESH_NETWORK_PROFILE=local
MYCOMESH_POOL_PUBLIC_URL=http://127.0.0.1:9800

# Bridge operator:
# Local/demo default:
MYCOMESH_BRIDGE_EXTRA_ARGS=--skip-direct-address-verification --allow-any-reputation-signer
# A public testnet Bridge accepts only signed provider descriptors containing
# myco+tcp://, myco+relay://, or myco+relays:// transport-key bindings.
# MYCOMESH_NETWORK_PROFILE=testnet
# MYCOMESH_NETWORK_ID=mycomesh-testnet
# MYCOMESH_POOL_PUBLIC_URL=https://bridge.example.com
# MYCOMESH_BRIDGE_EXTRA_ARGS=--provider-public-key <provider-node-public-key> --reputation-signer-public-key <proxy-public-key>

# Provider operator:
MYCOMESH_PROVIDER_POOL_URL=http://bridge:9800
# Use "provider" for local docker compose. Use a public DNS name for testnet.
MYCOMESH_PROVIDER_ADVERTISE_HOST=provider
MYCOMESH_PROVIDER_CAPACITY=1
MYCOMESH_PROVIDER_TRANSPORT=direct
# Local Compose Relay defaults. For an outbound-only remote Provider, replace
# all three values with the Relay's public endpoints and select relay mode.
MYCOMESH_PROVIDER_RELAY_HOST=relay
MYCOMESH_PROVIDER_RELAY_PORT=9901
MYCOMESH_PROVIDER_RELAY_PUBLIC_URL=http://relay:9900
# Select relay mode and replace the endpoints for a public Relay:
# MYCOMESH_PROVIDER_TRANSPORT=relay
# MYCOMESH_PROVIDER_RELAY_HOST=relay.example.com
# MYCOMESH_PROVIDER_RELAY_PORT=9901
# MYCOMESH_PROVIDER_RELAY_PUBLIC_URL=https://relay.example.com
# Local/demo default:
MYCOMESH_PROVIDER_EXTRA_ARGS=--allow-any-signed-consumer --allow-unreserved-requests
# Transport encryption is available for testnet, but the bundled Codex and
# generic OpenAI-compatible backends currently fail the production capability
# gate. Do not switch this profile until /health reports settlement_ready=true.
# MYCOMESH_NETWORK_PROFILE=testnet
# MYCOMESH_PROVIDER_ADVERTISE_HOST=provider.example.com
# MYCOMESH_PROVIDER_POOL_URL=https://bridge.example.com

# Relay operator. Public deployments must use the exact DNS name Providers use
# for MYCOMESH_PROVIDER_RELAY_HOST. The advertised provider port is used as the
# signed registration audience, so non-9901 public mappings are supported.
MYCOMESH_RELAY_ADVERTISE_HOST=relay
MYCOMESH_RELAY_ADVERTISE_CONTROL_PORT=9900
MYCOMESH_RELAY_ADVERTISE_PROVIDER_PORT=9901
MYCOMESH_RELAY_EXTRA_ARGS=--allow-any-signed-consumer
# For testnet, put the relay control port behind TLS and give providers that
# HTTPS URL so they advertise myco+relays://. Payloads remain end-to-end sealed
# between consumer and provider; the relay can still see routing metadata.

# Consumer proxy settings.
# Local placeholder only. Non-local profiles reject placeholders and secrets
# shorter than 32 characters.
MYCOMESH_ADMIN_TOKEN=change-me-admin-token
MYCOMESH_BILLING_MODE=local
# Wallet key registration is disabled by default, including in this local
# template. Set true only when deliberately testing/operating that endpoint.
MYCOMESH_PUBLIC_KEY_REGISTRATION=false
# Shared billing database issuance bounds. Public deployments still need a
# reverse-proxy per-source rate limit before enabling registration.
MYCOMESH_KEY_CHALLENGE_CAPACITY=1024
MYCOMESH_KEY_CHALLENGE_RATE_PER_MINUTE=120
# Contract-wallet registration RPC work is isolated from the ASGI event loop;
# this concurrency bound applies per process.
MYCOMESH_KEY_REGISTRATION_RPC_CONCURRENCY=4
MYCOMESH_KEY_REGISTRATION_RPC_TIMEOUT=20
# Per-challenge verification attempts before the shared claim fails closed.
MYCOMESH_KEY_REGISTRATION_MAX_ATTEMPTS=5
MYCOMESH_ALLOW_PUBLIC_GATEWAY_REGISTRATION=false
MYCOMESH_DISCOVERY_LIMIT=5
MYCOMESH_POOL_URL=http://bridge:9800
# Consumer Proxy request body limit, also enforced for chunked requests.
MYCOMESH_MAX_REQUEST_BYTES=1048576
MYCOMESH_MAX_CONCURRENT_REQUESTS=128
MYCOMESH_REQUEST_BODY_TIMEOUT_SECONDS=30
MYCOMESH_INFERENCE_CONCURRENCY=8
MYCOMESH_TIMEOUT_SECONDS=120
MYCOMESH_UVICORN_LIMIT_CONCURRENCY=128
MYCOMESH_UVICORN_KEEP_ALIVE_SECONDS=5
MYCOMESH_UVICORN_H11_MAX_INCOMPLETE_EVENT_BYTES=65536
# Canonical URL is always required. This value matches the local Docker proxy.
# Public profiles must replace it with an HTTPS URL using public DNS.
# API keys are bound to this URL's origin and are not portable across Gateways.
MYCOMESH_PUBLIC_GATEWAY_URL=http://127.0.0.1:8100/v1
# Public consumer proxy example (requires settlement_ready=true providers):
# MYCOMESH_NETWORK_PROFILE=testnet
# MYCOMESH_NETWORK_ID=mycomesh-testnet
# MYCOMESH_PUBLIC_GATEWAY_URL=https://gateway.example.com/v1
# MYCOMESH_PUBLIC_KEY_REGISTRATION=false
# MYCOMESH_POOL_URL=https://bridge-a.example.com,https://bridge-b.example.com

# Legacy Sepolia MycoMesh V2 deployment. Retained for compatibility/migration.
MYCOMESH_SETTLEMENT_VERSION=2
# The provider CLI requires a positive integer; V2 does not settle against this
# value, while V3 must match the immutable on-chain channel version.
MYCOMESH_PRICING_VERSION=1
ETH_CHAIN_ID=11155111
ETH_RPC_URL=
MYCO_DEPLOYMENT=/app/deployments/sepolia-myco-v2.json
MYCO_SETTLEMENT=0x780e8daa596981c055148633849a6dd90a0f8d15
MYCO_TOKEN=0x27ce5e8e3811a2664cb66cd1d7aea93f79dff1df
MYCO_TEST_USDC=0x860ccadc1e1926b718cfe4ec24fefa42095c6f68
MYCO_TREASURY=0x8d13f6c18ae30f223d985f39050cc8d9b00f90e1
MYCO_CHANNEL_HASH=0xdedf8b58276b80863f354409c963cbaddf4ca7d5b866d528ff1386d74b339104
MYCOMESH_CHAIN_SYNC_MIN_CONFIRMATIONS=6
MYCOMESH_SETTLEMENT_RPC_URL=
MYCOMESH_SETTLEMENT_CONTRACT=
MYCOMESH_SETTLEMENT_CHAIN_ID=11155111
MYCOMESH_SETTLEMENT_CONFIRMATIONS=6
MYCOMESH_SETTLEMENT_RPC_TIMEOUT=20

# V3 example: use one internally consistent V3 deployment record/address set.
# Do not mix these with the V2 addresses above. The deployer's TestUSDC has an
# unrestricted mint and must never be used as a production stablecoin.
# MYCOMESH_SETTLEMENT_VERSION=3
# MYCOMESH_PRICING_VERSION=1
# MYCO_DEPLOYMENT=/app/deployments/sepolia-myco-v3.json
# MYCO_SETTLEMENT=<v3-settlement>
# MYCOMESH_SETTLEMENT_RPC_URL=<v3-rpc-url>
# MYCOMESH_SETTLEMENT_CONTRACT=<v3-settlement>
# MYCO_TOKEN=<v3-myco-token>
# MYCO_TEST_USDC=<v3-test-usdc-test-only>
# MYCOMESH_PROVIDER_EXTRA_ARGS=--consumer-public-key <proxy-public-key> --payment-address <provider-address> --pricing-hash <v3-pricing-hash>

# Published ports bind to loopback by default. Keep HTTP control planes behind
# a same-host reverse proxy even when inference frames are end-to-end sealed.
MYCOMESH_BIND_ADDRESS=127.0.0.1
# Provider inference can use a separate interface from HTTP control planes.
MYCOMESH_PROVIDER_BIND_ADDRESS=127.0.0.1
# Relay control stays on MYCOMESH_BIND_ADDRESS behind HTTPS. Set this separate
# raw TCP listener to 0.0.0.0 only on a host intended to accept Providers.
MYCOMESH_RELAY_PROVIDER_BIND_ADDRESS=127.0.0.1
# Published ports on the host.
GATEWAY_PORT=8000
MYCOMESH_PROXY_PORT=8100
# Direct Providers advertise this same published host port to Bridges.
MYCOMESH_PROVIDER_PORT=9700
MYCOMESH_POOL_PORT=9800
MYCOMESH_RELAY_CONTROL_PORT=9900
MYCOMESH_RELAY_PROVIDER_PORT=9901
