# Public browser configuration. Never place private keys or admin tokens here.
VITE_API_BASE_URL=/proxy-api
VITE_BRIDGE_BASE_URL=/bridge-api
# Signed Provider descriptors use this canonical Bridge origin as their audience.
VITE_BRIDGE_AUDIENCE_URL=https://bridge.mycomesh.xyz
VITE_SITE_URL=https://mycomesh.xyz
VITE_APP_URL=/app
VITE_DOCS_URL=https://docs.mycomesh.xyz
VITE_GITHUB_URL=https://github.com/mycomesh
VITE_NETWORK_NAME=Sepolia testnet
VITE_NETWORK_ID=mycomesh-testnet
VITE_CHANNEL_ID=codex
VITE_CHANNEL=codex-standard-v1
VITE_BACKEND_POLICY=codex-app-server-postvalidated-v1
VITE_CHAIN_ID=11155111
# Browser-visible public endpoints only. Do not put RPC API keys in either value.
VITE_RPC_URL=
VITE_RPC_URLS=
VITE_EXPLORER_URL=https://sepolia.etherscan.io
VITE_MAX_INPUT_BYTES=8000
VITE_MAX_OUTPUT_TOKENS=2000

# Settlement V3 remains disabled unless every field below is present and
# VITE_PROTOCOL_VERSION is exactly 3. Do not insert legacy V2 addresses.
VITE_PROTOCOL_VERSION=
VITE_SETTLEMENT_ADDRESS=
VITE_STABLECOIN_ADDRESS=
VITE_TOKEN_ADDRESS=
VITE_TREASURY_ADDRESS=
VITE_GOVERNANCE_ADDRESS=
VITE_DEPLOYMENT_BLOCK=
# Public V4 session escrow manifest. When present, the Playground uses one
# activation transaction and relays subsequent receipts without wallet prompts.
VITE_SESSION_PROTOCOL_VERSION=4
VITE_SESSION_SETTLEMENT_ADDRESS=0x35021217c58358edd1e98ac4703d1a9fb464c8c3
VITE_SESSION_DEPLOYMENT_BLOCK=11298661
VITE_STABLECOIN_SYMBOL=tUSDC
VITE_STABLECOIN_DECIMALS=6
