FROM node:22-bookworm-slim AS codex-cli

RUN npm install --global --omit=dev @openai/codex@0.144.1 \
    && codex --version | grep -Fx "codex-cli 0.144.1"


FROM python:3.11-slim-bookworm

LABEL org.opencontainers.image.title="MycoMesh Codex Provider" \
      org.opencontainers.image.description="MycoMesh provider with Codex CLI 0.144.1" \
      org.opencontainers.image.source="https://github.com/Charleslzp/mycomesh"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/app \
    MYCOMESH_DATA_DIR=/data \
    GATEWAY_BACKEND=codex_app_server \
    CODEX_COMMAND=codex \
    CODEX_HOME=/data/codex-home \
    CODEX_WORKDIR=/workspace

RUN apt-get update \
    && apt-get install --yes --no-install-recommends \
        bash \
        ca-certificates \
        git \
        libstdc++6 \
        ripgrep \
    && rm -rf /var/lib/apt/lists/*

COPY --from=codex-cli /usr/local/bin/node /usr/local/bin/node
COPY --from=codex-cli /usr/local/lib/node_modules/@openai/codex /usr/local/lib/node_modules/@openai/codex

RUN ln -s /usr/local/lib/node_modules/@openai/codex/bin/codex.js /usr/local/bin/codex \
    && codex --version | grep -Fx "codex-cli 0.144.1"

WORKDIR /app

COPY requirements.txt pyproject.toml README.md ./
RUN python -m pip install --upgrade pip \
    && python -m pip install -r requirements.txt

COPY gateway ./gateway
COPY deployments ./deployments
COPY agents.example.json ./agents.example.json

RUN printf '#!/bin/sh\nexec python -m gateway "$@"\n' > /usr/local/bin/mycomesh \
    && chmod +x /usr/local/bin/mycomesh \
    && mkdir -p /data/codex-home /workspace

VOLUME ["/data", "/workspace"]
EXPOSE 8000 9700

ENTRYPOINT ["python", "-m", "gateway"]
CMD ["serve", "--host", "0.0.0.0", "--port", "8000"]
